{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/server.js"
    },
    {
      "src": "/health",
      "dest": "/backend/src/server.js"
    },
    {
      "src": "/favicon.ico",
      "dest": "/frontend/public/favicon.ico"
    },
    {
      "src": "/favicon.png",
      "dest": "/frontend/public/favicon.png"
    },
    {
      "src": "/login",
      "dest": "/frontend/pages/login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/frontend/pages/dashboard.html"
    },
    {
      "src": "/orders",
      "dest": "/frontend/pages/orders.html"
    },
    {
      "src": "/customers",
      "dest": "/frontend/pages/customers.html"
    },
    {
      "src": "/inventory",
      "dest": "/frontend/pages/inventory.html"
    },
    {
      "src": "/reports",
      "dest": "/frontend/pages/reports.html"
    },
    {
      "src": "/invoices",
      "dest": "/frontend/pages/invoices.html"
    },
    {
      "src": "/settings",
      "dest": "/frontend/pages/settings.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
